<!DOCTYPE html>
<html>
<head>
<link rel="stylesheet" href="styles.css">
<title>Panel Administrador</title>

<style>
:root {
    --brand-1: #0f766e;
    --brand-2: #0ea5a6;
    --brand-3: #134e4a;
    --surface: #ffffff;
    --surface-soft: #f8fafc;
    --line: #dbe3ea;
    --text: #0f172a;
}

body {
    margin: 0;
    padding: 24px;
    color: var(--text);
    background:
        radial-gradient(900px 400px at 10% -10%, rgba(20, 184, 166, 0.25), transparent 60%),
        radial-gradient(1000px 500px at 95% 0%, rgba(14, 165, 166, 0.2), transparent 60%),
        linear-gradient(135deg, #eaf6f6 0%, #f4f7fb 45%, #eef7f9 100%);
}

.container {
    max-width: 1280px;
    margin: 0 auto;
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 16px;
    padding: 24px;
    backdrop-filter: blur(6px);
    box-shadow: 0 12px 32px rgba(2, 8, 23, 0.08);
}

h1 {
    margin: 0 0 18px;
    color: var(--brand-3);
    letter-spacing: 0.2px;
}

.seccion {
    display: none;
    margin-top: 18px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 16px;
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.05);
}

.activo { display: block; }

.menu-botones {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 8px;
}

.menu-botones button {
    margin-right: 0;
}

button {
    border: none;
    border-radius: 10px;
    padding: 9px 14px;
    background: linear-gradient(135deg, var(--brand-2), #0284c7);
    color: #fff;
    font-weight: 600;
    cursor: pointer;
    transition: transform .08s ease, filter .2s ease;
}

button:hover {
    filter: brightness(1.05);
}

button:active {
    transform: translateY(1px);
}

input, select, textarea {
    border-radius: 10px;
    border: 1px solid #cfd8e3;
    background: #fff;
}

table {
    width: 100%;
    margin-top: 10px;
    border-collapse: collapse;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
}

th, td {
    padding: 10px;
    text-align: left;
    border-bottom: 1px solid #e7edf4;
}

thead th {
    background: #f2f7fb;
    color: #0f172a;
    font-weight: 700;
}

tbody tr:hover {
    background: #f8fbff;
}

.tabla-scroll-equipos { overflow-x: auto; }
#tabla_equipos td, #tabla_equipos th { vertical-align: middle; }
#tabla_equipos th:nth-child(7), #tabla_equipos td:nth-child(7) { min-width: 260px; }
#tabla_equipos td.col-equipo, #tabla_equipos td.col-serie, #tabla_equipos td.col-ubicacion { word-break: break-word; }
.acciones-linea { display: grid; grid-template-columns: repeat(2, minmax(100px, 1fr)); gap: 6px; }
.acciones-linea button { width: 100%; margin: 0; padding: 7px 8px; white-space: nowrap; }

.alerta {
    background-color: #ffe5e5;
    color: #c62828;
    font-weight: bold;
}
</style>
</head>

<body>
<div class="container">

<div class="panel-header">
<h1>Panel Administrador</h1>
<div class="logout-menu">
<button class="logout-toggle" onclick="toggleLogoutMenu(event)">▾</button>
<div id="logout-dropdown" class="logout-dropdown">
<button onclick="cerrarSesion()">Cerrar sesion</button>
</div>
</div>
</div>

<div class="menu-botones">
<button onclick="mostrarSeccion('lineas')">Lineas</button>
<button onclick="mostrarSeccion('materiales')">Materiales Ensamble</button>
<button onclick="mostrarSeccion('herramienta_modulo')">Herramienta de modulo</button>
<button onclick="mostrarSeccion('equipos')">Equipos</button>
<button onclick="mostrarSeccion('solicitudes')">Solicitudes</button>
<button onclick="mostrarSeccion('material_lineas')">Material por Linea</button>
<button onclick="abrirUsuarios()">Usuarios</button>
<button onclick="mostrarSeccion('exportar')">Exportar</button>
</div>

<!-- ================= LINEAS ================= -->
<div id="lineas" class="seccion activo">

<h2>Administracion de lineas de PFA</h2>

<input type="text" id="nombre_linea" placeholder="Nombre de la linea">
<button onclick="agregarLinea()">Agregar</button>

<table>
<thead>
<tr>
<th>ID</th>
<th>Nombre</th>
<th>Accion</th>
</tr>
</thead>

<tbody id="tabla_lineas"></tbody>
</table>

</div>

<!-- ================= MATERIALES ================= -->
<div id="materiales" class="seccion">

<h2>GestiÃ³n de Materiales</h2>

<input type="text" id="nombre_material" placeholder="Nombre"><br><br>
<select id="tipo_material">
    <option value="consumible">Consumible</option>
    <option value="herramienta">Herramienta</option>
</select><br><br>

<input type="number" id="cantidad_stock" placeholder="Cantidad en Stock"><br><br>
<input type="number" id="stock_minimo" placeholder="Stock Ma­nimo"><br><br>

<button onclick="agregarMaterial()">Agregar Material</button>

<hr>

<!-- ðŸ”Ž BUSCADOR -->
<input type="text" 
id="buscar_material"
placeholder="Buscar material por nombre"
onkeyup="buscarMaterial()"
style="margin-bottom:15px; padding:8px; width:300px;">

<table>
<thead>
<tr>
<th>Nombre</th>
<th>Stock</th>
<th>Agregar</th>
<th>Acciones</th>
</tr>
</thead>
<tbody id="tabla_materiales"></tbody>
</table>

</div>

<!-- ================= HERRAMIENTA MODULO ================= -->
<div id="herramienta_modulo" class="seccion">
<h2>Gestion de Herramienta de Modulo</h2>
<input type="text" id="nombre_herramienta_modulo" placeholder="Nombre"><br><br>
<input type="text" id="descripcion_herramienta_modulo" placeholder="Descripcion"><br><br>
<input type="number" id="cantidad_herramienta_modulo" placeholder="Cantidad"><br><br>
<input type="number" id="precio_herramienta_modulo" step="0.01" placeholder="Precio por unidad"><br><br>
<button onclick="agregarHerramientaModulo()">Agregar Herramienta</button>
<hr>
<input type="text"
id="buscar_herramienta_modulo"
placeholder="Buscar herramienta por nombre"
onkeyup="buscarHerramientaModulo()"
style="margin-bottom:15px; padding:8px; width:300px;">
<table>
<thead>
<tr>
<th>Nombre</th>
<th>Descripcion</th>
<th>Cantidad</th>
<th>Precio Unitario</th>
<th>Agregar</th>
<th>Acciones</th>
</tr>
</thead>
<tbody id="tabla_herramienta_modulo"></tbody>
</table>
</div>

<!-- ================= EQUIPOS ================= -->
<div id="equipos" class="seccion">

<h2>GestiÃ³n de Equipos Individuales</h2>

<input type="text" id="nombre_equipo" placeholder="Nombre del equipo"><br><br>

<input type="text" id="descripcion_equipo" placeholder="Descripcion"><br><br>

<input type="text" id="numero_serie" placeholder="NÃºmero de Serie"><br><br>

<input type="text" id="numero_activo" placeholder="Fix Asset / Low Value"><br><br>

<select id="ubicacion_equipo"></select>
<br><br>

<button onclick="agregarEquipoIndividual()">Agregar Equipo</button>

<hr>

<input type="text" id="buscar_equipo"
placeholder="Buscar por Serie o Nombre"
onkeyup="filtrarEquipos()"
style="margin-bottom:15px; padding:8px; width:300px;">

<div class="tabla-scroll-equipos">
<table>
<thead>
<tr>
<th>Equipo</th>
<th>Descripcion</th>
<th>Serie</th>
<th>Fix Asset / Low Value</th>
<th>Ubicacion</th>
<th>Condicion</th>
<th>Acciones</th>
</tr>
</thead>
<tbody id="tabla_equipos"></tbody>
</table>
</div>

</div>

<!-- ================= SOLICITUDES ================= -->
<div id="solicitudes" class="seccion">

<h2>Solicitudes Pendientes</h2>

<table>
<thead>
<tr>
<th>TÃ©cnico</th>
<th>Equipo</th>
<th>LÃ­nea</th>
<th>Fecha</th>
<th>AcciÃ³n</th>
</tr>
</thead>
<tbody id="tabla_solicitudes"></tbody>
</table>

</div>


<!-- ================= MATERIAL POR LINEA ================= -->
<div id="material_lineas" class="seccion">

<h2>Material Actualmente en Lineas</h2>

<select id="filtro_linea_material" style="max-width:300px; margin-right:10px;">
    <option value="todas">Todas las lineas</option>
</select>

<select id="filtro_seccion_material" style="max-width:250px; margin-right:10px;">
    <option value="todas">Todas las secciones</option>
    <option value="ensamble">Ensamble</option>
    <option value="modulo">Herramienta de modulo</option>
</select>

<button onclick="cargarMaterialPorLinea()">Filtrar</button>
<button onclick="exportarMaterialPorLinea()">Exportar</button>

<table>
<thead>
<tr>
<th>Linea</th>
<th>Seccion</th>
<th>Material</th>
<th>Acumulado (Nuevo)</th>
<th>Cantidad en Cambio</th>
</tr>
</thead>
<tbody id="tabla_material_lineas"></tbody>
</table>

</div>

<!-- ================= USUARIOS ================= -->
<div id="usuarios" class="seccion">

    <h2>Agregar Usuario</h2>

    <div style="display:flex; flex-direction:column; max-width:400px; gap:10px;">
        
        <label>Nombre de empleado:</label>
        <input type="text" id="nombre_usuario" placeholder="Nombre completo">
        <label>NÃºmero de empleado (ID):</label>
        <input type="text" id="numero_id_usuario" placeholder="Ej: 12345">

        <label>TÃ©cnico / Empleado / Supervisor:</label>
        <select id="rol_usuario">
            <option value="tecnico">TÃ©cnico</option>
            <option value="empleado">Empleado</option>
            <option value="supervisor">Supervisor</option>
        </select>

        <label>ContraseÃ±a:</label>
        <input type="password" id="password_usuario" placeholder="Ingresar contraseÃ±a">

        <label>Confirmar contraseÃ±a:</label>
        <input type="password" id="confirmar_password" placeholder="Repetir contraseÃ±a">

        <button onclick="crearUsuario()">Agregar Usuario</button>
    </div>

    <hr style="margin:30px 0;">

    <input 
    type="text"
    id="buscar_usuario"
    placeholder="Buscar por nombre o ID"
    onkeyup="buscarUsuarios()"
    style="margin-bottom:15px; padding:8px; width:300px;">

    <h2>Tabla de Empleados, TÃ©cnicos y Supervisores</h2>

    <table border="1" cellpadding="8" style="width:100%; max-width:1200px;">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Usuario (ID)</th>
                <th>Rol</th>
                <th>Estado</th>
                <th>Contrasena</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody id="tabla-usuarios">
        </tbody>
    </table>

</div>

<!-- ================= EXPORTAR ================= -->
<div id="exportar" class="seccion">

<h2>Exportaciones</h2>

<button onclick="exportarInventario()">-Exportar inventario a Excel</button>

<hr>

<label>Desde:</label>
<input type="date" id="fecha_inicio">

<label>Hasta:</label>
<input type="date" id="fecha_fin">

<hr style="margin:15px 0;"><button onclick="exportarRequisiciones()">- Exportar requisiciones a Excel</button>

</div>

<script>

function estaEditandoFormulario(){
    const el = document.activeElement;
    if (!el) return false;
    const tag = el.tagName;
    return tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT" || el.isContentEditable;
}

function mostrarSeccion(id){
document.querySelectorAll(".seccion").forEach(s=>s.classList.remove("activo"));
document.getElementById(id).classList.add("activo");

if (id === "lineas") {
    cargarLineas();
} else if (id === "materiales") {
    const texto = document.getElementById("buscar_material")?.value?.trim() || "";
    cargarMateriales(texto);
} else if (id === "herramienta_modulo") {
    const texto = document.getElementById("buscar_herramienta_modulo")?.value?.trim() || "";
    cargarHerramientasModulo(texto);
} else if (id === "equipos") {
    cargarEquiposAdmin();
} else if (id === "solicitudes") {
    cargarSolicitudes();
} else if (id === "material_lineas") {
    cargarMaterialPorLinea();
} else if (id === "usuarios") {
    cargarUsuarios();
}
}

function obtenerSeccionActivaAdmin(){
const activa = document.querySelector(".seccion.activo");
return activa ? activa.id : "";
}

function refrescarSeccionActivaAdmin(){
const activa = obtenerSeccionActivaAdmin();

if (activa === "lineas") {
    cargarLineas();
} else if (activa === "materiales") {
    const texto = document.getElementById("buscar_material")?.value?.trim() || "";
    cargarMateriales(texto);
} else if (activa === "herramienta_modulo") {
    const texto = document.getElementById("buscar_herramienta_modulo")?.value?.trim() || "";
    cargarHerramientasModulo(texto);
} else if (activa === "equipos") {
    cargarEquiposAdmin();
} else if (activa === "solicitudes") {
    cargarSolicitudes();
} else if (activa === "material_lineas") {
    cargarMaterialPorLinea();
} else if (activa === "usuarios") {
    cargarUsuarios();
}
}

/* ================= LINEAS ================= */

async function cargarLineas(){
try{
    const res = await fetch("http://localhost:3000/lineas");

    if(!res.ok){
        if(res.status === 401 || res.status === 403){
            alert("SesiÃ³n expirada o sin permisos. Inicia sesiÃ³n de nuevo.");
            window.location.href = "login.html";
            return;
        }
        throw new Error("Error al cargar lÃ­neas");
    }

    const data = await res.json();
    if(!Array.isArray(data)) throw new Error("Respuesta invÃ¡lida de /lineas");

    const tabla = document.getElementById("tabla_lineas");
    tabla.innerHTML = "";

    const select = document.getElementById("linea_select");
    if(select) select.innerHTML = "";

    const ubicacionSelect = document.getElementById("ubicacion_equipo");
    if(ubicacionSelect) ubicacionSelect.innerHTML = "";

    const filtroLineaMaterial = document.getElementById("filtro_linea_material");
    if(filtroLineaMaterial){
        filtroLineaMaterial.innerHTML = `<option value="todas">Todas las lineas</option>`;
    }

    data.forEach(l=>{
        const nombreSeguro = String(l.nombre ?? "").replace(/'/g, "\\'");
        tabla.innerHTML += `
        <tr>
            <td>${l.id}</td>
            <td>${l.nombre}</td>
            <td>
                <button onclick="editarLinea(${l.id}, '${nombreSeguro}')">Editar</button>
                <button onclick="eliminarLinea(${l.id})">Eliminar</button>
            </td>
        </tr>`;

        if(select){
            select.innerHTML += `<option value="${l.id}">${l.nombre}</option>`;
        }

        if(ubicacionSelect){
            ubicacionSelect.innerHTML += `<option value="${l.nombre}">${l.nombre}</option>`;
        }

        if(filtroLineaMaterial){
            filtroLineaMaterial.innerHTML += `<option value="${l.nombre}">${l.nombre}</option>`;
        }
    });
}catch(err){
    console.error("Error en cargarLineas:", err);
}
}


async function agregarLinea(){
const nombre=document.getElementById("nombre_linea").value;

await fetch("http://localhost:3000/lineas",{
method:"POST",
headers:{ "Content-Type":"application/json"},
body:JSON.stringify({nombre})
});

cargarLineas();
}

async function eliminarLinea(id){
if(!confirm("Â¿Eliminar lÃ­nea?")) return;
await fetch(`http://localhost:3000/lineas/${id}`,{method:"DELETE"});
cargarLineas();
}

async function editarLinea(id, nombreActual){
const nuevoNombre = prompt("Editar nombre de la lÃ­nea:", nombreActual);
if(nuevoNombre === null) return;

const nombre = nuevoNombre.trim();
if(!nombre){
alert("El nombre no puede estar vacÃ­o");
return;
}

const res = await fetch(`http://localhost:3000/lineas/${id}`,{
method:"PUT",
headers:{ "Content-Type":"application/json" },
body: JSON.stringify({ nombre })
});

if(!res.ok){
const data = await res.json().catch(() => ({}));
alert(data.error || "Error al editar lÃ­nea");
return;
}

cargarLineas();
}


//* ================= MATERIALES ================= */

async function cargarMateriales(busqueda = ""){

const url = busqueda 
? `http://localhost:3000/materiales?buscar=${busqueda}`
: "http://localhost:3000/materiales";

const res = await fetch(url);
const data = await res.json();

const tabla = document.getElementById("tabla_materiales");
tabla.innerHTML = "";

data.forEach(m => {

let clase = m.cantidad_stock <= m.stock_minimo ? "alerta" : "";
const nombreSeguro = String(m.nombre ?? "").replace(/'/g, "\\'");
const tipoSeguro = String(m.tipo ?? "").replace(/'/g, "\\'");

tabla.innerHTML += `
<tr class="${clase}">
<td>${m.nombre}</td>
<td>
${m.cantidad_stock}
<br><small>MÃ­nimo: ${m.stock_minimo}</small>
</td>
<td>
<input type="number" id="sumar_${m.id}" min="1" style="width:80px;">
<button onclick="sumarStock(${m.id})">âž•</button>
</td>
<td>
    <div class="acciones-linea">
        <button onclick="editarMaterial(${m.id}, '${nombreSeguro}', '${tipoSeguro}', ${m.stock_minimo})">Editar</button>
        <button onclick="eliminarMaterial(${m.id})">Eliminar</button>
    </div>
</td>
</tr>`;
});
}

async function buscarMaterial(){
const texto = document.getElementById("buscar_material").value.trim();
cargarMateriales(texto);
}

async function sumarStock(id){
const cantidad = document.getElementById("sumar_"+id).value;
if(!cantidad || cantidad<=0){ alert("Cantidad invÃ¡lida"); return; }

await fetch(`http://localhost:3000/materiales/${id}/stock`,{
method:"PUT",
headers:{ "Content-Type":"application/json"},
body:JSON.stringify({ nuevo_stock: "+"+cantidad })
});

cargarMateriales();
}

async function agregarMaterial(){

const material={
nombre:document.getElementById("nombre_material").value.trim(),
cantidad_stock:parseInt(document.getElementById("cantidad_stock").value),
tipo: document.getElementById("tipo_material").value,
stock_minimo:parseInt(document.getElementById("stock_minimo").value)
};

if(!material.nombre){
alert("El nombre es obligatorio");
return;
}

const response=await fetch("http://localhost:3000/materiales",{
method:"POST",
headers:{ "Content-Type":"application/json"},
body:JSON.stringify(material)
});

if(!response.ok){
const data=await response.json();
alert(data.error);
return;
}

document.getElementById("nombre_material").value="";
document.getElementById("cantidad_stock").value="";
document.getElementById("stock_minimo").value="";

cargarMateriales();
}

async function eliminarMaterial(id){
if(!confirm("Â¿Eliminar material?")) return;
await fetch(`http://localhost:3000/materiales/${id}`,{method:"DELETE"});
cargarMateriales();
}

async function editarMaterial(id, nombreActual, tipoActual, stockMinimoActual){
const nombreNuevo = prompt("Editar nombre del material:", nombreActual);
if(nombreNuevo === null) return;

const nombre = nombreNuevo.trim();
if(!nombre){
alert("El nombre no puede estar vacio");
return;
}

const tipoNuevo = prompt("Editar tipo (consumible/herramienta):", tipoActual);
if(tipoNuevo === null) return;

const tipo = tipoNuevo.trim().toLowerCase();
if(tipo !== "consumible" && tipo !== "herramienta"){
alert("Tipo invalido");
return;
}

const stockMinNuevo = prompt("Editar stock minimo:", stockMinimoActual);
if(stockMinNuevo === null) return;

const stock_minimo = parseInt(stockMinNuevo, 10);
if(Number.isNaN(stock_minimo) || stock_minimo < 0){
alert("Stock minimo invalido");
return;
}

const response = await fetch(`http://localhost:3000/materiales/${id}`,{
method:"PUT",
headers:{ "Content-Type":"application/json"},
body:JSON.stringify({ nombre, tipo, stock_minimo })
});

if(!response.ok){
const data = await response.json().catch(() => ({}));
alert(data.error || "Error al editar material");
return;
}

cargarMateriales();
}

/* ================= HERRAMIENTA MODULO ================= */

async function cargarHerramientasModulo(busqueda = ""){
const url = busqueda
? `http://localhost:3000/herramienta-modulo?buscar=${busqueda}`
: "http://localhost:3000/herramienta-modulo";

const res = await fetch(url);
const data = await res.json();

const tabla = document.getElementById("tabla_herramienta_modulo");
tabla.innerHTML = "";

data.forEach(h => {
const nombreSeguro = String(h.nombre ?? "").replace(/'/g, "\\'");
const descripcionSegura = String(h.descripcion ?? "").replace(/'/g, "\\'");

tabla.innerHTML += `
<tr>
<td>${h.nombre}</td>
<td>${h.descripcion || "-"}</td>
<td>${h.cantidad}</td>
<td>${Number(h.precio_por_unidad || 0).toFixed(2)}</td>
<td>
<input type="number" id="sumar_hm_${h.id}" min="1" style="width:80px;">
<button onclick="sumarCantidadHerramientaModulo(${h.id})">+</button>
</td>
<td>
    <div class="acciones-linea">
        <button onclick="editarHerramientaModulo(${h.id}, '${nombreSeguro}', '${descripcionSegura}', ${h.cantidad}, ${h.precio_por_unidad || 0})">Editar</button>
        <button onclick="eliminarHerramientaModulo(${h.id})">Eliminar</button>
    </div>
</td>
</tr>`;
});
}

function buscarHerramientaModulo(){
const texto = document.getElementById("buscar_herramienta_modulo").value.trim();
cargarHerramientasModulo(texto);
}

async function agregarHerramientaModulo(){
const nombre = document.getElementById("nombre_herramienta_modulo").value.trim();
const descripcion = document.getElementById("descripcion_herramienta_modulo").value.trim();
const cantidad = parseInt(document.getElementById("cantidad_herramienta_modulo").value, 10);
const precio_por_unidad = parseFloat(document.getElementById("precio_herramienta_modulo").value);

if(!nombre){
alert("El nombre es obligatorio");
return;
}
if(Number.isNaN(cantidad) || cantidad < 0){
alert("Cantidad invalida");
return;
}
if(Number.isNaN(precio_por_unidad) || precio_por_unidad < 0){
alert("Precio invalido");
return;
}

const response = await fetch("http://localhost:3000/herramienta-modulo", {
method:"POST",
headers:{ "Content-Type":"application/json" },
body: JSON.stringify({ nombre, descripcion, cantidad, precio_por_unidad })
});

if(!response.ok){
const data = await response.json().catch(() => ({}));
alert(data.error || "Error al agregar herramienta");
return;
}

document.getElementById("nombre_herramienta_modulo").value = "";
document.getElementById("descripcion_herramienta_modulo").value = "";
document.getElementById("cantidad_herramienta_modulo").value = "";
document.getElementById("precio_herramienta_modulo").value = "";

cargarHerramientasModulo();
}

async function sumarCantidadHerramientaModulo(id){
const cantidad = document.getElementById("sumar_hm_" + id).value;
if(!cantidad || parseInt(cantidad, 10) <= 0){
alert("Cantidad invalida");
return;
}

const response = await fetch(`http://localhost:3000/herramienta-modulo/${id}/cantidad`, {
method:"PUT",
headers:{ "Content-Type":"application/json" },
body: JSON.stringify({ cambio: "+" + cantidad })
});

if(!response.ok){
const data = await response.json().catch(() => ({}));
alert(data.error || "No se pudo actualizar cantidad");
return;
}

cargarHerramientasModulo();
}

async function editarHerramientaModulo(id, nombreActual, descripcionActual, cantidadActual, precioActual){
const nombreNuevo = prompt("Editar nombre:", nombreActual);
if(nombreNuevo === null) return;
const nombre = nombreNuevo.trim();
if(!nombre){
alert("Nombre obligatorio");
return;
}

const descripcionNueva = prompt("Editar descripcion:", descripcionActual || "");
if(descripcionNueva === null) return;
const descripcion = descripcionNueva.trim();

const cantidadNueva = prompt("Editar cantidad:", String(cantidadActual ?? 0));
if(cantidadNueva === null) return;
const cantidad = parseInt(cantidadNueva, 10);
if(Number.isNaN(cantidad) || cantidad < 0){
alert("Cantidad invalida");
return;
}

const precioNuevo = prompt("Editar precio por unidad:", String(precioActual ?? 0));
if(precioNuevo === null) return;
const precio_por_unidad = parseFloat(precioNuevo);
if(Number.isNaN(precio_por_unidad) || precio_por_unidad < 0){
alert("Precio invalido");
return;
}

const response = await fetch(`http://localhost:3000/herramienta-modulo/${id}`, {
method:"PUT",
headers:{ "Content-Type":"application/json" },
body: JSON.stringify({ nombre, descripcion, cantidad, precio_por_unidad })
});

if(!response.ok){
const data = await response.json().catch(() => ({}));
alert(data.error || "Error al editar herramienta");
return;
}

cargarHerramientasModulo();
}

async function eliminarHerramientaModulo(id){
if(!confirm("Eliminar herramienta de modulo?")) return;
const response = await fetch(`http://localhost:3000/herramienta-modulo/${id}`, { method:"DELETE" });
if(!response.ok){
const data = await response.json().catch(() => ({}));
alert(data.error || "No se pudo eliminar");
return;
}
cargarHerramientasModulo();
}

/* ================= EQUIPOS ================= */

function formatearEstadoEquipo(estado){
if (estado === "danado") return "Danado";
if (estado === "en_uso") return "En uso";
return "Funcional";
}

async function actualizarCondicionEquipo(id, condicion){
const response = await fetch(`http://localhost:3000/equipos-individuales/${id}/condicion`, {
method:"PUT",
headers:{ "Content-Type":"application/json"},
body: JSON.stringify({ condicion })
});

const data = await response.json().catch(() => ({}));
if(!response.ok){
alert(data.error || "No se pudo actualizar la condicion");
return;
}

cargarEquiposAdmin();
}



async function devolverManualEquipo(id){
if(!confirm("Confirmar devolucion manual de este equipo?")) return;

const response = await fetch(`http://localhost:3000/equipos-individuales/${id}/devolver-manual`, {
method:"PUT"
});

const data = await response.json().catch(() => ({}));
if(!response.ok){
alert(data.error || "No se pudo devolver manualmente");
return;
}

alert("Equipo recibido correctamente");
cargarEquiposAdmin();
cargarSolicitudes();
cargarMaterialPorLinea();
}
async function cargarEquiposAdmin(){
const res=await fetch("http://localhost:3000/equipos-individuales");
const data=await res.json();

const tabla=document.getElementById("tabla_equipos");
tabla.innerHTML="";

data.forEach(e=>{
const nombreSeguro = String(e.nombre ?? "").replace(/'/g, "\\'");
const descripcionSegura = String(e.descripcion ?? "").replace(/'/g, "\\'");
const serieSegura = String(e.numero_serie ?? "").replace(/'/g, "\\'");
const activoSeguro = String(e.numero_activo ?? "").replace(/'/g, "\\'");
const ubicacionSegura = String(e.ubicacion ?? "").replace(/'/g, "\\'");

tabla.innerHTML+=`
<tr>
<td class="col-equipo">${e.nombre}</td>
<td>${e.descripcion || "-"}</td>
<td class="col-serie">${e.numero_serie}</td>
<td>${e.numero_activo || "-"}</td>
<td class="col-ubicacion">${e.ubicacion||"-"}</td>
<td>${formatearEstadoEquipo(e.estado)}</td>
<td>
    <div class="acciones-linea">
        <button onclick="actualizarCondicionEquipo(${e.id}, 'funcional')">Funcional</button>
        <button onclick="actualizarCondicionEquipo(${e.id}, 'danado')">Danado</button>
        <button onclick="devolverManualEquipo(${e.id})">Retornar</button>
        <button onclick="editarEquipo(${e.id}, '${nombreSeguro}', '${descripcionSegura}', '${serieSegura}', '${activoSeguro}', '${ubicacionSegura}')">Editar</button>
        <button onclick="eliminarEquipo(${e.id})">Eliminar</button>
    </div>
</td>
</tr>`;
});
}

async function agregarEquipoIndividual(){

const equipo = {
nombre: document.getElementById("nombre_equipo").value.trim(),
descripcion: document.getElementById("descripcion_equipo").value.trim(),
numero_serie: document.getElementById("numero_serie").value.trim(),
numero_activo: document.getElementById("numero_activo").value.trim(),
ubicacion: document.getElementById("ubicacion_equipo").value
};

const response = await fetch("http://localhost:3000/equipos-individuales",{
method:"POST",
headers:{ "Content-Type":"application/json"},
body: JSON.stringify(equipo)
});

if(!response.ok){
const data = await response.json();
alert(data.error);
return;
}

alert("Equipo agregado correctamente");

document.getElementById("nombre_equipo").value="";
document.getElementById("descripcion_equipo").value="";
document.getElementById("numero_serie").value="";
document.getElementById("numero_activo").value="";

cargarEquiposAdmin();
}

async function eliminarEquipo(id){
if(!confirm("Â¿Eliminar equipo?")) return;
await fetch(`http://localhost:3000/equipos-individuales/${id}`,{method:"DELETE"});
cargarEquiposAdmin();
}

async function editarEquipo(id, nombreActual, descripcionActual, serieActual, activoActual, ubicacionActual){
const nombreNuevo = prompt("Editar nombre del equipo:", nombreActual);
if(nombreNuevo === null) return;
const nombre = nombreNuevo.trim();
if(!nombre){
alert("El nombre es obligatorio");
return;
}

const descripcionNueva = prompt("Editar descripcion:", descripcionActual || "");
if(descripcionNueva === null) return;
const descripcion = descripcionNueva.trim();

const serieNueva = prompt("Editar numero de serie:", serieActual);
if(serieNueva === null) return;
const numero_serie = serieNueva.trim();
if(!numero_serie){
alert("El numero de serie es obligatorio");
return;
}

const activoNuevo = prompt("Editar Fix Asset / Low Value:", activoActual || "");
if(activoNuevo === null) return;
const numero_activo = activoNuevo.trim();

const ubicacionNueva = prompt("Editar ubicacion:", ubicacionActual || "");
if(ubicacionNueva === null) return;
const ubicacion = ubicacionNueva.trim();

const response = await fetch(`http://localhost:3000/equipos-individuales/${id}`,{
method:"PUT",
headers:{ "Content-Type":"application/json"},
body: JSON.stringify({ nombre, descripcion, numero_serie, numero_activo, ubicacion })
});

if(!response.ok){
const data = await response.json().catch(() => ({}));
alert(data.error || "Error al editar equipo");
return;
}

cargarEquiposAdmin();
}

function filtrarEquipos(){
const filtro=document.getElementById("buscar_equipo").value.toLowerCase();
const filas=document.querySelectorAll("#tabla_equipos tr");

filas.forEach(fila=>{
const texto=fila.innerText.toLowerCase();
fila.style.display=texto.includes(filtro) ? "" : "none";
});
}

/* ================= SOLICITUDES ================= */

async function cargarSolicitudes(){

    const tabla = document.getElementById("tabla_solicitudes");
    tabla.innerHTML = "";

    // ðŸ”µ Solicitudes nuevas
    const resPendientes = await fetch("http://localhost:3000/asignaciones/pendientes");
    const pendientes = await resPendientes.json();

    pendientes.forEach(s=>{
        tabla.innerHTML+=`
        <tr>
            <td>${s.tecnico}</td>
            <td>${s.equipo}</td>
            <td>${s.linea}</td>
            <td>${new Date(s.fecha_solicitud).toLocaleString()}</td>
            <td>
                <button onclick="aprobarSolicitud(${s.id})">Aprobar</button>
                <button onclick="rechazarSolicitud(${s.id})">Rechazar</button>
            </td>
        </tr>`;
    });

    // ðŸŸ¡ Devoluciones pendientes
    const resDev = await fetch("http://localhost:3000/asignaciones/devoluciones-pendientes");
    const devoluciones = await resDev.json();

    devoluciones.forEach(s=>{
        tabla.innerHTML+=`
        <tr style="background:#fff3cd;">
            <td>${s.tecnico}</td>
            <td>${s.equipo}</td>
            <td>${s.linea}</td>
            <td>Pendiente devoluciÃ³n</td>
                        <td>
                <button onclick="aprobarDevolucion(${s.id})">
                    Aprobar devoluciÃ³n
                </button>
                <button onclick="rechazarDevolucion(${s.id})">
                    Rechazar devoluciÃ³n
                </button>
            </td>
        </tr>`;
    });
}

async function aprobarSolicitud(id){

    const response = await fetch(
        `http://localhost:3000/asignaciones/${id}/aprobar`,
        { method:"PUT" }
    );

    if(!response.ok){
        alert("Error al aprobar solicitud");
        return;
    }

    cargarSolicitudes();
}

async function rechazarSolicitud(id){

    const response = await fetch(
        `http://localhost:3000/asignaciones/${id}/rechazar`,
        { method:"PUT" }
    );

    if(!response.ok){
        alert("Error al rechazar");
        return;
    }

    cargarSolicitudes();
}

async function aprobarDevolucion(id){

    const response = await fetch(
        `http://localhost:3000/asignaciones/${id}/aprobar-devolucion`,
        { method:"PUT" }
    );

    if(!response.ok){
        alert("Error al aprobar devoluciÃ³n");
        return;
    }

    cargarSolicitudes();
}
async function rechazarDevolucion(id){

    const response = await fetch(
        `http://localhost:3000/asignaciones/${id}/rechazar-devolucion`,
        { method:"PUT" }
    );

    if(!response.ok){
        alert("Error al rechazar devoluciÃ³n");
        return;
    }

    cargarSolicitudes();
}


async function cargarMaterialPorLinea(){
const linea = document.getElementById("filtro_linea_material")?.value || "todas";
const seccion = document.getElementById("filtro_seccion_material")?.value || "todas";

const url = `http://localhost:3000/materiales-por-linea?linea=${encodeURIComponent(linea)}&seccion=${encodeURIComponent(seccion)}`;
const res = await fetch(url);
const data = await res.json();

const tabla = document.getElementById("tabla_material_lineas");
if(!tabla) return;

if(!res.ok){
    tabla.innerHTML = `<tr><td colspan="5">${data.error || "Error al cargar informacion"}</td></tr>`;
    return;
}

tabla.innerHTML = "";
if(!Array.isArray(data) || data.length === 0){
    tabla.innerHTML = `<tr><td colspan="5">Sin datos</td></tr>`;
    return;
}

data.forEach(item => {
    tabla.innerHTML += `
    <tr>
        <td>${item.linea || "-"}</td>
        <td>${item.seccion || "-"}</td>
        <td>${item.material || "-"}</td>
        <td>${item.acumulado_nuevo || 0}</td>
        <td>${item.cambios_registrados || 0}</td>
    </tr>`;
});
}


function exportarMaterialPorLinea(){
const linea = document.getElementById("filtro_linea_material")?.value || "todas";
const seccion = document.getElementById("filtro_seccion_material")?.value || "todas";

window.location.href =
`http://localhost:3000/exportar-materiales-por-linea?linea=${encodeURIComponent(linea)}&seccion=${encodeURIComponent(seccion)}`;
}
/* ================= Sesion ================= */
function toggleLogoutMenu(event){
    if (event) event.stopPropagation();
    const menu = document.getElementById("logout-dropdown");
    if (!menu) return;
    menu.style.display = menu.style.display === "block" ? "none" : "block";
}

function cerrarSesion(){
    localStorage.removeItem("usuario");
    localStorage.removeItem("token");
    window.location.href = "login.html";
}

document.addEventListener("click", (e) => {
    const wrap = document.querySelector(".logout-menu");
    const menu = document.getElementById("logout-dropdown");
    if (!wrap || !menu) return;
    if (!wrap.contains(e.target)) {
        menu.style.display = "none";
    }
});

const usuarioAuth = JSON.parse(localStorage.getItem("usuario"));
if (!usuarioAuth || usuarioAuth.rol !== "admin") {
    alert("Acceso no autorizado");
    window.location.href = "login.html";
}

const originalFetch = window.fetch.bind(window);
window.fetch = (input, init = {}) => {
    const headers = new Headers(init.headers || {});
    const token = localStorage.getItem("token");
    if (token) headers.set("Authorization", "Bearer " + token);
    return originalFetch(input, { ...init, headers });
};

/* ================= EXPORTAR ================= */
function exportarInventario(){
    window.location.href="http://localhost:3000/exportar-inventario";
}

function exportarRequisiciones(){
    const inicio=document.getElementById("fecha_inicio").value;
    const fin=document.getElementById("fecha_fin").value;
    const usuario=JSON.parse(localStorage.getItem("usuario"));

    if(!inicio || !fin){
        alert("Seleccione rango de fechas");
        return;
    }

    if(!usuario){
        alert("Usuario no identificado");
        return;
    }

    window.location.href=
    `http://localhost:3000/exportar-requisiciones?fecha_inicio=${inicio}&fecha_fin=${fin}&usuario_id=${usuario.id}`;
}
/* ================= INICIO ================= */

cargarLineas();
cargarMateriales();
cargarHerramientasModulo();
cargarEquiposAdmin();
cargarSolicitudes();
cargarMaterialPorLinea();


setInterval(() => {
    if (estaEditandoFormulario()) return;
    refrescarSeccionActivaAdmin();
}, 5000);

</script>
